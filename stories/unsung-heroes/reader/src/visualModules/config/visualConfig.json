      }
    }
  ],
  "transitions": {
    "duration": 1200,
    "easing": "ease-in-out"
  },
  "global": {
    "respectReducedMotion": true,
    "targetFrameRate": 60,
    "enablePerformanceMonitoring": true,
    "autoAdjustQuality": true,
    "mobileQualityReduction": 0.7
  }
}
